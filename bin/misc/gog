#!/bin/sh
CMD=$1
shift
GAME=$(export IFS='|'; echo "$*")
GAME=${GAME:-$(find -type d | tr -d '\n' | sed 's_\.\./__;s_\./_|_g')}
gog() {
    lgogdownloader \
        --platform w \
        --no-platform-detection \
        --no-subdirectories \
        --include i \
        "$@"
}
gg() { gog --game "^($GAME)$" "$@"; }
case $CMD in
    list)
        gog --list
        ;;
    pull)
        gg --download --size-only
        ;;
    clean)
        gg --check-orphans --delete-orphans
        ;;
    check)
        gg --status --size-only | grep -v ^OK
        ;;
    verify)
        gg --status | grep -v ^OK
        ;;
    repair)
        gg --download --repair
        ;;
esac
